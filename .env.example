# Jira — Used by skills, curl-based queries, and scripts (ic-activity, jira skill queries)
# JIRA_API_TOKEN is also consumed by the jira CLI (ankitpokhrel/jira-cli) for issue creation.
# Note: the jira CLI stores its server config independently via `jira init` (~/.config/.jira/)
JIRA_EMAIL=your.email@yourcompany.com
JIRA_API_TOKEN=
JIRA_URL=https://yourcompany.atlassian.net
