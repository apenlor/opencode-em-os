# GitHub — Personal Access Token with repo and read:org scopes
GITHUB_TOKEN=

# Jira — Used by scripts that call the Jira REST API directly
# Note: the jira CLI authenticates independently via ~/.config/jira/
JIRA_EMAIL=your.email@yourcompany.com
JIRA_API_TOKEN=
JIRA_URL=https://yourcompany.atlassian.net
